{
  "extends": "astro/tsconfigs/strict",
  "include": [
    ".astro/types.d.ts",
    "**/*"
  ],
  "exclude": [
    "dist"
  ],
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "paths": {
      "@fachada/core": ["../fachada-core/src/index.ts"],
      "@fachada/core/*": ["../fachada-core/src/*"]
    }
  }
}