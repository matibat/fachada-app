---
import { siteConfig } from '../../config';
import Button from '../ui/Button.astro';
---

<section class="min-h-screen flex items-center justify-center px-4 py-20" data-testid="hero-section">
  <div class="max-w-4xl mx-auto text-center">
    <h1
      class="text-5xl md:text-7xl font-bold mb-6"
      data-testid="hero-title"
      style="color: var(--accent);"
    >
      {siteConfig.name}
    </h1>
    <p class="text-xl md:text-2xl mb-4" data-testid="hero-role" style="color: var(--text-secondary);">
      {siteConfig.role}
    </p>
    <p class="text-lg mb-8 max-w-2xl mx-auto" data-testid="hero-description" style="color: var(--text-secondary);">
      {siteConfig.description}
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <Button href="#projects" variant="primary" size="lg" class="hero-primary-cta" >
        View Work
      </Button>
      <Button href="#contact" variant="outline" size="lg">
        Get in Touch
      </Button>
    </div>
  </div>
</section>

<style>
  :global(.hero-primary-cta) {
    box-shadow: 0 8px 18px var(--shadow);
  }
</style>
