---
import Card from '../ui/Card.astro';
import Badge from '../ui/Badge.astro';
import Button from '../ui/Button.astro';

export interface Props {
  title: string;
  description: string;
  stack: string[];
  coverImage: string;
  liveUrl?: string;
  githubUrl?: string;
  slug: string;
}

const { title, description, stack, coverImage, liveUrl, githubUrl, slug } = Astro.props;
---

<Card>
  <div class="space-y-4">
    <img
      src={coverImage}
      alt={title}
      class="w-full h-48 object-cover rounded-lg"
      loading="lazy"
    />
    <h3 class="text-2xl font-bold">{title}</h3>
    <p class="text-gray-600 dark:text-gray-300">{description}</p>
    <div class="flex flex-wrap gap-2">
      {stack.map((tech) => (
        <Badge variant="primary">{tech}</Badge>
      ))}
    </div>
    <div class="flex gap-3 pt-2">
      <Button href={`/projects/${slug.replace('.md', '')}`} variant="primary" size="sm">
        View Case Study
      </Button>
      {liveUrl && (
        <Button href={liveUrl} variant="outline" size="sm">
          Live Demo
        </Button>
      )}
      {githubUrl && (
        <Button href={githubUrl} variant="outline" size="sm">
          GitHub
        </Button>
      )}
    </div>
  </div>
</Card>
