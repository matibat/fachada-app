---
import { getActiveAppConfig } from '../app/AppLoader';

const appConfig = getActiveAppConfig();
const siteConfig = appConfig.seo;
const currentYear = new Date().getFullYear();

const subsections = appConfig.siteTree?.landing.subsections ?? [];
const navItems = [
  { href: '/', label: 'Home' },
  ...subsections
    .filter(s => !s.meta.path.substring(1).includes('/'))
    .map(s => ({
      href: s.meta.path,
      label: s.id.split('-').map((w: string) => w.charAt(0).toUpperCase() + w.slice(1)).join(' '),
    })),
];
---

<footer class="px-4 py-12 border-t" style="border-color: var(--border);">
  <div class="max-w-6xl mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-8">
      <!-- Left: Social Links -->
      <div>
        <p class="font-semibold mb-4" style="color: var(--text-primary);">Follow</p>
        <div class="flex gap-4">
          {siteConfig.social.github && (
            <a href={siteConfig.social.github} class="transition-colors footer-link" style="color: var(--text-secondary);">
              GitHub
            </a>
          )}
          {siteConfig.social.linkedin && (
            <a href={siteConfig.social.linkedin} class="transition-colors footer-link" style="color: var(--text-secondary);">
              LinkedIn
            </a>
          )}
          {siteConfig.social.twitter && (
            <a href={siteConfig.social.twitter} class="transition-colors footer-link" style="color: var(--text-secondary);">
              Twitter
            </a>
          )}
        </div>
      </div>

      <!-- Center: Portfolio Sections -->
      <div>
        <p class="font-semibold mb-4" style="color: var(--text-primary);">Portfolio</p>
        <nav class="flex flex-col gap-2">
          {navItems.map(item => (
            <a href={item.href} class="transition-colors footer-link" style="color: var(--text-secondary);">
              {item.label}
            </a>
          ))}
        </nav>
      </div>

      <!-- Right: Contact -->
      <div>
        <p class="font-semibold mb-4" style="color: var(--text-primary);">Contact</p>
        <a
          href={`mailto:${siteConfig.social.email}`}
          class="transition-colors footer-link"
          style="color: var(--accent);"
        >
          {siteConfig.social.email}
        </a>
        <p class="text-sm mt-4" style="color: var(--text-secondary);">
          {siteConfig.location.city}, {siteConfig.location.country}
        </p>
      </div>
    </div>

    <!-- Copyright line -->
    <div class="border-t pt-6" style="border-color: var(--border);">
      <p style="color: var(--text-secondary); text-align: center; font-size: 0.875rem;">
        © {currentYear} {siteConfig.name}. All rights reserved.
      </p>
    </div>
  </div>
</footer>

<style>
  .footer-link:hover {
    color: var(--accent) !important;
  }
</style>
