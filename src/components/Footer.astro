---
import { siteConfig } from '../config';

const currentYear = new Date().getFullYear();
---

<footer class="px-4 py-12 border-t" style="border-color: var(--border);">
  <div class="max-w-6xl mx-auto">
    <div class="flex flex-col md:flex-row justify-between items-center gap-4">
      <p style="color: var(--text-secondary);">
        © {currentYear} {siteConfig.name}. All rights reserved.
      </p>
      <nav class="flex gap-6">
        <a href="/" class="transition-colors footer-link" style="color: var(--text-secondary);">
          Home
        </a>
        <a href="/projects" class="transition-colors footer-link" style="color: var(--text-secondary);">
          Projects
        </a>
        <a href="/blog" class="transition-colors footer-link" style="color: var(--text-secondary);">
          Blog
        </a>
      </nav>
    </div>
  </div>
</footer>

<style>
  .footer-link:hover {
    color: var(--accent) !important;
  }
</style>
