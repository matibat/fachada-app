---
import { siteConfig } from '../config';

const currentYear = new Date().getFullYear();
---

<footer class="px-4 py-12 border-t border-gray-200 dark:border-gray-800">
  <div class="max-w-6xl mx-auto">
    <div class="flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-gray-600 dark:text-gray-400">
        © {currentYear} {siteConfig.name}. All rights reserved.
      </p>
      <nav class="flex gap-6">
        <a href="/" class="text-gray-600 hover:text-blue-600 dark:text-gray-400 dark:hover:text-blue-400 transition-colors">
          Home
        </a>
        <a href="/projects" class="text-gray-600 hover:text-blue-600 dark:text-gray-400 dark:hover:text-blue-400 transition-colors">
          Projects
        </a>
        <a href="/blog" class="text-gray-600 hover:text-blue-600 dark:text-gray-400 dark:hover:text-blue-400 transition-colors">
          Blog
        </a>
      </nav>
    </div>
  </div>
</footer>
