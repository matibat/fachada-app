---
/**
 * Page header with config-driven navigation.
 * - Logo/name on left (from appConfig.seo.name)
 * - Nav items derived from top-level siteTree landing subsections
 * - Contact CTA on right
 */
import { getActiveAppConfig } from '../app/AppLoader';

interface Props {
  currentPath?: string;
}

const { currentPath = '/' } = Astro.props;
const appConfig = getActiveAppConfig();
const siteConfig = appConfig.seo;

const subsections = appConfig.siteTree?.landing.subsections ?? [];
const navItems = subsections
  .filter(s => !s.meta.path.substring(1).includes('/'))
  .map(s => ({
    href: s.meta.path,
    label: s.id.split('-').map((w: string) => w.charAt(0).toUpperCase() + w.slice(1)).join(' '),
    active: currentPath === s.meta.path || currentPath.startsWith(s.meta.path + '/'),
  }));

const isLanding = currentPath === '/';
---

<header class="border-b sticky top-0 z-50 backdrop-blur" style="border-color: var(--border); background-color: rgba(var(--bg-primary-rgb), 0.95);">
  <div class="max-w-6xl mx-auto px-4 py-4 flex items-center justify-between">
    <!-- Left: Logo / Name -->
    <a href="/" class="font-semibold text-lg transition-colors hover:text-accent" style="color: var(--text-primary);">
      {siteConfig.name}
    </a>

    <!-- Center: Navigation (hidden on mobile) -->
    <nav class="hidden md:flex gap-8">
      <a
        href="/"
        class="transition-colors"
        style={{ color: isLanding ? 'var(--accent)' : 'var(--text-secondary)' }}
      >
        Home
      </a>
      {navItems.map(item => (
        <a
          href={item.href}
          class="transition-colors"
          style={{ color: item.active ? 'var(--accent)' : 'var(--text-secondary)' }}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <!-- Right: Contact CTA -->
    {siteConfig.social.email && (
      <a
        href={`mailto:${siteConfig.social.email}`}
        class="px-4 py-2 rounded-lg transition-colors text-sm font-semibold"
        style={{ backgroundColor: 'var(--accent)', color: 'var(--text-primary)' }}
      >
        Get in touch
      </a>
    )}
  </div>
</header>

<style>
  header {
    --bg-primary-rgb: 15, 23, 42; /* fallback for dark theme */
    background-color: var(--bg-primary);
  }

  @media (max-width: 768px) {
    header {
      position: relative;
      backdrop-filter: blur(4px);
    }
  }
</style>
