---
import type { AboutLayout } from "@fachada/core";
import AboutCard from "@fachada/core/astro/widgets/about/AboutCard.astro";
import AboutPlain from "@fachada/core/astro/widgets/about/AboutPlain.astro";

export interface Props {
  layout?: AboutLayout;
}

const { layout = "card" } = Astro.props;
---

{layout === "card" && <AboutCard />}
{layout === "plain" && <AboutPlain />}
