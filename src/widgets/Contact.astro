---
import type { ContactLayout } from '../types/layout.types';
import ContactCentered from './contact/ContactCentered.astro';
import ContactSplit from './contact/ContactSplit.astro';

export interface Props {
  layout?: ContactLayout;
}

const { layout = 'centered' } = Astro.props;
---

{layout === 'centered' && <ContactCentered />}
{layout === 'split' && <ContactSplit />}
