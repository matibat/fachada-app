---
import type { ProjectsLayout } from '../types/layout.types';
import ProjectsGrid3 from './projects/ProjectsGrid3.astro';
import ProjectsGrid2 from './projects/ProjectsGrid2.astro';
import ProjectsList from './projects/ProjectsList.astro';

export interface Props {
  layout?: ProjectsLayout;
  filterRoles?: string[];
}

const { layout = 'grid-3', filterRoles } = Astro.props;
---

{layout === 'grid-3' && <ProjectsGrid3 filterRoles={filterRoles} />}
{layout === 'grid-2' && <ProjectsGrid2 filterRoles={filterRoles} />}
{layout === 'list' && <ProjectsList filterRoles={filterRoles} />}
