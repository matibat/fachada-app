---
import type { HeroLayout } from "@fachada/core";
import HeroCentered from "@fachada/core/astro/widgets/hero/HeroCentered.astro";
import HeroSplit from "@fachada/core/astro/widgets/hero/HeroSplit.astro";

export interface Props {
  layout?: HeroLayout;
}

const { layout = "centered" } = Astro.props;
---

{layout === "centered" && <HeroCentered />}
{layout === "split" && <HeroSplit />}
