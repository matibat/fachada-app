---
import BaseLayout from '../layouts/BaseLayout.astro';
import WidgetRenderer from '../core/widgets/WidgetRenderer.astro';
import Footer from '../components/Footer.astro';
import StructuredData from '../components/StructuredData.astro';
import { siteConfig } from '../config';
import { profileConfig } from '../profile.config';
import { getCollection } from 'astro:content';

const personSchema = {
  name: siteConfig.name,
  url: siteConfig.url,
  jobTitle: siteConfig.roles.find(r => r.id === siteConfig.primaryRole)?.title ?? siteConfig.roles[0]?.title,
  sameAs: [
    siteConfig.social.github,
    siteConfig.social.linkedin,
    siteConfig.social.twitter,
  ].filter(Boolean),
};

const projects = await getCollection('projects');
const blog = await getCollection('blog');
---

<BaseLayout>
  <StructuredData type="Person" data={personSchema} />
  <main>
    <WidgetRenderer
      sections={profileConfig.sections}
      projectsCount={projects.length}
      blogCount={blog.length}
    />
  </main>
  <Footer />
</BaseLayout>
