---
/**
 * Engineering subsection page — technical depth & credibility.
 *
 * Marketing: specificity = trust. Targets recruiters and clients.
 * Hook-Meat-CTA pyramid:
 *   Hook  — role-specific 60vh two-col hero (WebGL · React · Node.js headline)
 *   Meat  — 3-col projects grid (engineer filtered) → skills → process philosophy
 *   CTA   — "Available for contracts. Email me."
 *
 * Scaffold: Header (currentPath=/engineering) + breadcrumb + Footer.
 * Content: pulled entirely from siteConfig.roles[engineer].
 * Widgets used: Projects (grid-3, filterRoles=['engineer']), Contact (split).
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import StructuredData from '../components/StructuredData.astro';
import Projects from '../widgets/Projects.astro';
import Contact from '../widgets/Contact.astro';
import { siteConfig } from '../config';

const engineeringRole = siteConfig.roles.find(r => r.id === 'engineer');
if (!engineeringRole) {
  return new Response('Role not found', { status: 404 });
}

const personSchema = {
  name: siteConfig.name,
  url: `${siteConfig.url}/engineering`,
  jobTitle: engineeringRole.title,
  description: engineeringRole.description,
  sameAs: [
    siteConfig.social.github,
    siteConfig.social.linkedin,
    siteConfig.social.twitter,
  ].filter(Boolean),
};

const engineeringContactMessage =
  "Available for engineering contracts. Let's build real-time systems, full-stack solutions, or whatever your technical challenge is.";
---

<BaseLayout
  title={`${siteConfig.name} — Software Engineer | TypeScript, WebGL, React`}
  description="Portfolio: real-time 3D systems, full-stack development, TypeScript, WebGL, React, Node.js."
>
  <StructuredData type="Person" data={personSchema} />
  <Header currentPath="/engineering" />

  <main data-page="engineering">

    <!-- Breadcrumb: context trail -->
    <div class="eng-breadcrumb">
      <div class="max-w-6xl mx-auto px-4">
        <nav aria-label="Breadcrumb">
          <a href="/" class="breadcrumb-link">← Home</a>
          <span class="breadcrumb-sep" aria-hidden="true">/</span>
          <span class="breadcrumb-current">Engineering</span>
        </nav>
      </div>
    </div>

    <!-- ── HOOK: 60vh two-column role-specific hero ─────────────────────── -->
    <section class="eng-hero" data-testid="engineering-hero">
      <div class="max-w-6xl mx-auto px-4 w-full eng-hero-grid">

        <!-- Left column: role identity -->
        <div class="eng-hero-identity">
          <p class="eng-overline">
            {engineeringRole.title}
          </p>
          <h1 class="eng-headline">
            Depth in WebGL,<br />React, Node.js.
          </h1>
          <div class="eng-specialties" role="list" aria-label="Core specialties">
            {engineeringRole.specialties.map(s => (
              <span class="eng-tag" role="listitem">{s}</span>
            ))}
          </div>
        </div>

        <!-- Right column: description + CTA -->
        <div class="eng-hero-content">
          <p class="eng-description">
            {engineeringRole.description}
          </p>
          <a
            href={`mailto:${siteConfig.social.email}`}
            class="eng-cta-btn"
            aria-label="Send Matías an email"
          >
            Email me
          </a>
          <p class="eng-availability">
            Open to contracts · Remote-friendly
          </p>
        </div>
      </div>
    </section>

    <!-- ── MEAT 1: Featured projects — 3-col, engineer-filtered ─────────── -->
    <section class="eng-section" data-testid="engineering-projects">
      <div class="max-w-6xl mx-auto px-4">
        <h2 class="eng-section-heading">Featured Projects</h2>
        <Projects layout="grid-3" filterRoles={['engineer']} />
      </div>
    </section>

    <!-- ── MEAT 2: Skills breakdown — 3 categories from role config ──────── -->
    {engineeringRole.skills && (
      <section class="eng-section eng-section--alt" data-testid="engineering-skills">
        <div class="max-w-6xl mx-auto px-4">
          <h2 class="eng-section-heading">Skills & Expertise</h2>
          <div class="eng-skills-grid">
            {engineeringRole.skills.map(category => (
              <div class="eng-skill-category">
                <h3 class="eng-skill-heading">{category.name}</h3>
                <div class="eng-skill-tags" role="list">
                  {category.skills.map(skill => (
                    <span class="eng-skill-tag" role="listitem">{skill}</span>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- ── MEAT 3: Engineering philosophy ───────────────────────────────── -->
    {engineeringRole.about && (
      <section class="eng-section" data-testid="engineering-process">
        <div class="max-w-3xl mx-auto px-4">
          <h2 class="eng-section-heading">How I approach engineering</h2>
          <div class="eng-process-body">
            {engineeringRole.about.paragraphs.map(para => (
              <p class="eng-process-para">{para}</p>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- ── CTA: Available for contracts ─────────────────────────────────── -->
    <Contact layout="split" message={engineeringContactMessage} />

  </main>
  <Footer />
</BaseLayout>

<style>
  /* ── Breadcrumb ────────────────────────────────────────────── */
  .eng-breadcrumb {
    padding: 1.25rem 0 0;
    font-size: 0.875rem;
  }
  .breadcrumb-link {
    color: var(--text-secondary);
    text-decoration: none;
    transition: color var(--transition);
  }
  .breadcrumb-link:hover { color: var(--accent); }
  .breadcrumb-sep { color: var(--text-secondary); margin: 0 0.5rem; }
  .breadcrumb-current { color: var(--text-primary); }

  /* ── Hero ──────────────────────────────────────────────────── */
  .eng-hero {
    min-height: 60vh;
    display: flex;
    align-items: center;
    padding: 4rem 0;
  }
  .eng-hero-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }
  @media (min-width: 768px) {
    .eng-hero-grid {
      grid-template-columns: 1fr 1fr;
      gap: 5rem;
      align-items: center;
    }
    .eng-hero-identity {
      border-right: 1px solid var(--border);
      padding-right: 5rem;
    }
  }
  .eng-overline {
    font-family: var(--font-mono, monospace);
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-secondary);
    margin-bottom: 1.25rem;
  }
  .eng-headline {
    font-family: var(--font-heading, sans-serif);
    font-weight: var(--heading-weight, 700);
    font-size: clamp(2rem, 4vw, 3.25rem);
    line-height: 1.15;
    letter-spacing: var(--heading-letter-spacing, -0.02em);
    color: var(--text-primary);
    margin-bottom: 1.75rem;
  }
  .eng-specialties {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .eng-tag {
    font-family: var(--font-mono, monospace);
    font-size: 0.8rem;
    padding: 0.3rem 0.75rem;
    border: 1px solid var(--border);
    border-radius: var(--border-radius, 6px);
    color: var(--text-secondary);
  }
  .eng-description {
    font-size: 1.125rem;
    line-height: var(--body-line-height, 1.75);
    color: var(--text-secondary);
    margin-bottom: 2rem;
  }
  .eng-cta-btn {
    display: inline-block;
    padding: 0.875rem 2rem;
    background-color: var(--accent);
    color: var(--button-text-color, #fff);
    font-weight: 600;
    border-radius: var(--border-radius, 6px);
    text-decoration: none;
    transition: opacity var(--transition);
    margin-bottom: 1rem;
  }
  .eng-cta-btn:hover { opacity: 0.88; }
  .eng-availability {
    font-size: 0.875rem;
    font-family: var(--font-mono, monospace);
    color: var(--text-secondary);
    margin-top: 0.5rem;
  }

  /* ── Sections ──────────────────────────────────────────────── */
  .eng-section {
    padding: var(--spacing-section, 5rem) 0;
  }
  .eng-section--alt {
    background-color: var(--bg-secondary);
  }
  .eng-section-heading {
    font-family: var(--font-heading, sans-serif);
    font-weight: var(--heading-weight, 700);
    font-size: clamp(1.5rem, 2.5vw, 2rem);
    color: var(--text-primary);
    margin-bottom: 3rem;
    letter-spacing: var(--heading-letter-spacing, -0.01em);
  }

  /* ── Skills ────────────────────────────────────────────────── */
  .eng-skills-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
  }
  @media (min-width: 640px) { .eng-skills-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .eng-skills-grid { grid-template-columns: repeat(3, 1fr); } }
  .eng-skill-category {
    padding: 1.5rem;
    border: 1px solid var(--border);
    border-radius: var(--border-radius, 8px);
    background-color: var(--bg-primary);
  }
  .eng-skill-heading {
    font-size: 0.875rem;
    font-family: var(--font-mono, monospace);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--accent);
    margin-bottom: 1rem;
  }
  .eng-skill-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .eng-skill-tag {
    font-size: 0.875rem;
    padding: 0.3rem 0.7rem;
    background-color: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: 99px;
    color: var(--text-secondary);
  }

  /* ── Process ───────────────────────────────────────────────── */
  .eng-process-body {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .eng-process-para {
    font-size: 1rem;
    line-height: var(--body-line-height, 1.75);
    color: var(--text-secondary);
  }
</style>
